# ─── API ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── AGENDAMIENTO ─────────────────────────────────────────────────────────
CALENDLY_LINK=https://calendly.com/fracchia-propiedades/visita

# ─── WHATSAPP CONTACTO ASESOR (el que el lead puede escribir directo) ──────
WHATSAPP_ASESOR=5491112345678

# ─── GRUPO INTERNO DE WHATSAPP (JID del grupo de asesores) ────────────────
# Para obtenerlo: una vez conectado el agente, enviá un mensaje al grupo
# y el JID aparece en los logs. Formato: 1234567890-1234567890@g.us
GRUPO_WHATSAPP_JID=

# ─── SERVIDOR ─────────────────────────────────────────────────────────────
PORT=3000
SESSION_PATH=./sessions
